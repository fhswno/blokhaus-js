{
  "name": "blokhaus-monorepo",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun run --filter blokhaus-playground dev",
    "dev:docs": "bun run --filter blokhaus-docs dev",
    "build": "bun run --filter blokhaus-playground build",
    "build:docs": "bun run --filter blokhaus-docs build",
    "typecheck": "bunx tsc --noEmit",
    "test": "cd apps/playground && bunx playwright test",
    "lint": "bun run --filter blokhaus-playground lint"
  }
}
